# QPlix tenant base URL
QPLIX_BASE_URL=https://gkk.qplix.com

# Auth: SSO via headed browser. Run `npx tsx src/index.ts login` and complete
# SSO in the Chromium window that opens. The persistent browser profile
# (.browser-profile/) means the M365 session sticks across runs — first
# login does the full MFA dance, subsequent logins are usually silent.
#
# The CLI captures the bearer token from the InvestorPortal's first XHR,
# stores it in .token-cache.json, and uses it for subsequent API calls.
# When the token expires (~1h), re-run `login`.
